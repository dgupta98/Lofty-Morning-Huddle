# Copy to .env.local and fill in your values

# InsForge project (from insforge.dev dashboard)
NEXT_PUBLIC_INSFORGE_URL=https://YOUR_PROJECT_ID.insforge.dev
NEXT_PUBLIC_INSFORGE_ANON_KEY=
INSFORGE_SERVICE_KEY=

# HuggingFace API token (from huggingface.co/settings/tokens)
HF_API_KEY=hf_...

# Demo agent UUID (from InsForge after seeding)
DEMO_AGENT_ID=
